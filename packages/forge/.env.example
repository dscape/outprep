# Required for autonomous agent loop
ANTHROPIC_API_KEY=sk-ant-...

# Required for oracle (Claude → ChatGPT → Claude pipeline)
# Optional — oracle degrades to single-model if missing
OPENAI_API_KEY=sk-...

# Optional overrides
FORGE_MAX_EXPERIMENTS=20
FORGE_ORACLE_RATE_LIMIT=5
FORGE_EVAL_TIMEOUT_MS=300000
