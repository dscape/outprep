# Outprep — environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Postgres ──────────────────────────────────────────────────────────────
# Required for all player/game data queries.
# For local development, use Docker: docker compose up -d
# For production, use Neon, Supabase, Railway, or any Postgres host.
DATABASE_URL=postgres://outprep:outprep@localhost:5432/outprep

# ─── Forge (autonomous research agent) ─────────────────────────────────────
# Required for the forge research agent and the forge dashboard session launcher.
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─── Cron Authentication (production only) ─────────────────────────────────
# Vercel sets CRON_SECRET automatically for cron-triggered requests.
# Not needed for local development.
# CRON_SECRET=
